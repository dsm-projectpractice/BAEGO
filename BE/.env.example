# Naver Search API (Local Search + Reverse Geocoding)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Naver Maps API (Reverse Geocoding v2)
NAVER_MAP_CLIENT_ID=
NAVER_MAP_CLIENT_SECRET=

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=baego
DB_USER=
DB_PASSWORD=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Server
PORT=3000
ALLOWED_ORIGIN=http://localhost:5173
NODE_ENV=development

# Rate Limit (requests per minute per IP)
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=30

# Cache TTL (seconds)
CACHE_TTL_RESTAURANTS=1800
CACHE_TTL_GEOCODE=86400
